<UserControl x:Class="AIBox.FirstRun.Phases.DownloadPhase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Downloading required content"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                CornerRadius="3"
                Padding="14">
            <ItemsControl x:Name="ItemsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Grid.Column="1"
                                         Minimum="0"
                                         Maximum="{Binding BytesTotal}"
                                         Value="{Binding BytesDownloaded}"
                                         Margin="8,0"
                                         VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DisplayProgress}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                CornerRadius="3"
                Padding="14,10"
                Margin="0,12,0,0">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Overall" VerticalAlignment="Center"/>
                    <ProgressBar x:Name="OverallProgress"
                                 Grid.Column="1"
                                 Margin="8,0"
                                 Minimum="0" Maximum="100"
                                 Height="18"/>
                    <TextBlock x:Name="OverallText"
                               Grid.Column="2"
                               Text="0 / 0 GB"
                               VerticalAlignment="Center"/>
                </Grid>
                <TextBlock x:Name="StatsText"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,8,0,0"
                           Text="Speed: -- · ETA: -- · Disk free: --"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="PauseButton"
                    Content="Pause"
                    Click="OnPauseClick"
                    Margin="0,0,8,0"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</UserControl>
