<UserControl x:Class="AIBox.FirstRun.Phases.BootstrapFlow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StepHeader"
                   Grid.Row="0"
                   Text="Create your admin account"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                CornerRadius="3"
                Padding="20">
            <ContentControl x:Name="SubStepHost"/>
        </Border>

        <!-- ACL warning banner: shown when .env ACL lockdown fails (non-elevated run) -->
        <Border x:Name="AclWarningBanner"
                Grid.Row="2"
                Background="#FFF3CD"
                BorderBrush="#FFCA28"
                BorderThickness="1"
                CornerRadius="3"
                Padding="12,8"
                Margin="0,8,0,0"
                Visibility="Collapsed">
            <TextBlock TextWrapping="Wrap"
                       Foreground="#5C4000"
                       FontSize="12">
                <Run FontWeight="SemiBold">Security warning: </Run>
                <Run>ACLs on .env could not be locked down. The master encryption key may be readable by other users on this machine. Re-run as Administrator to secure it.</Run>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="PrimaryButton"
                    Content="Continue"
                    Click="OnPrimaryClick"
                    MinWidth="140"/>
        </StackPanel>
    </Grid>
</UserControl>
