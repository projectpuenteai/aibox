<UserControl x:Class="AIBox.FirstRun.Phases.AdminPromptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="480" HorizontalAlignment="Stretch">
        <TextBlock Text="This is the account you'll use to log into the AIBox web UI."
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Username" Margin="0,0,0,4"/>
        <TextBox x:Name="UsernameBox" Text="puenteAdmin" Margin="0,0,0,12"/>

        <TextBlock Text="Password (min 8 characters)" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,4" PasswordChanged="OnPasswordChanged"/>
        <TextBlock x:Name="StrengthLabel" Text=" " Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12"/>

        <TextBlock Text="Confirm password" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmBox" Margin="0,0,0,12"/>

        <TextBlock Text="There is no email-based password recovery on an offline system. Store this somewhere safe."
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}"
                   FontStyle="Italic"
                   Margin="0,8,0,0"/>
    </StackPanel>
</UserControl>
