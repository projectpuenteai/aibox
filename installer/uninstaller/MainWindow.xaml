<Window x:Class="AIBox.Uninstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIBox Uninstaller"
        Width="640" Height="480"
        Background="#FF1B1F24"
        Foreground="#FFE6E9EF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="AIBox Uninstaller"
                       FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Inno already removes the install tree. Use the options below to also remove user data."
                       Margin="0,4,0,0"
                       Foreground="#FF8B95A7"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#FF252A33"
                CornerRadius="3"
                Padding="20">
            <StackPanel>
                <CheckBox x:Name="DataCheck"
                          Margin="0,0,0,16">
                    <CheckBox.Content>
                        <StackPanel>
                            <TextBlock Text="Also remove ~100 GB of downloaded content"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Wikipedia ZIMs, Chroma index, models, Kolibri channel files."
                                       Foreground="#FF8B95A7"/>
                        </StackPanel>
                    </CheckBox.Content>
                </CheckBox>

                <CheckBox x:Name="UserDataCheck"
                          Margin="0,0,0,16">
                    <CheckBox.Content>
                        <StackPanel>
                            <TextBlock Text="Also remove encrypted user data and chat history"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="ai-control SQLite, chat logs, uploaded documents. Cannot be undone."
                                       Foreground="#FF8B95A7"/>
                        </StackPanel>
                    </CheckBox.Content>
                </CheckBox>

                <TextBlock Text="Always performed (regardless of checkboxes above):"
                           Margin="0,16,0,8"
                           Foreground="#FF8B95A7"/>
                <TextBlock Text="• Remove AIBox-Puente-Startup scheduled task"
                           Foreground="#FF8B95A7"/>
                <TextBlock Text="• Remove puente.link entry from hosts file"
                           Foreground="#FF8B95A7"/>
                <TextBlock Text="• Tear down Windows Mobile Hotspot configuration"
                           Foreground="#FF8B95A7"/>
                <TextBlock Text="• Zero out encryption key and DPAPI password blob"
                           Foreground="#FF8B95A7"/>
                <TextBlock Text="• Docker Desktop is NEVER uninstalled (other apps may depend on it)"
                           Margin="0,8,0,0"
                           Foreground="#FFEF5350"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="ProceedButton"
                    Content="Uninstall"
                    Click="OnProceedClick"
                    Padding="16,8"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    Background="#FFEF5350"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Click="OnCancelClick"
                    Padding="16,8"
                    MinWidth="100"
                    Background="#FF252A33"
                    Foreground="#FFE6E9EF"/>
        </StackPanel>
    </Grid>
</Window>
