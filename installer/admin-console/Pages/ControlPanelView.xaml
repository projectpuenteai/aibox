<UserControl x:Class="AIBox.AdminConsole.Pages.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header (logo + title + pill) -->
            <RowDefinition Height="Auto"/>  <!-- hero button -->
            <RowDefinition Height="Auto"/>  <!-- Wi-Fi card -->
            <RowDefinition Height="*"/>     <!-- console pane -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Width="64" Height="64" CornerRadius="32"
                    Background="#EDF4FF" ClipToBounds="True">
                <Image Source="pack://application:,,,/Resources/circlelogo.png"
                       Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource BrandTextDark}"/>
                <TextBlock Text="{Binding Subtitle}" FontSize="12" Margin="0,2,0,0"
                           Foreground="{StaticResource BrandTextSoft}"/>
            </StackPanel>

            <Border Grid.Column="2" CornerRadius="14" Padding="14,7"
                    Background="{Binding PillBackground}"
                    BorderBrush="{Binding PillBorder}"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{Binding PillDot}"/>
                    <TextBlock Text="{Binding PillText}"
                               FontWeight="Bold" FontSize="12"
                               Foreground="{Binding PillForeground}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Hero Start/Stop button -->
        <Button Grid.Row="1"
                Style="{StaticResource HeroButton}"
                Background="{Binding ButtonBrush}"
                Content="{Binding ButtonLabel}"
                IsEnabled="{Binding ButtonEnabled}"
                Command="{Binding ToggleCommand}"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"/>

        <!-- Wi-Fi readout card -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource WifiLabel}"
                           Text="{Binding SsidLabel}" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource WifiValue}"
                           Text="{Binding Ssid}" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource WifiLabel}"
                           Text="{Binding PasswordLabel}" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource WifiValue}"
                           Text="{Binding Password}" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Style="{StaticResource WifiLabel}"
                           Text="{Binding IpLabel}"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource WifiValue}"
                           Text="{Binding IpDisplay}"
                           Foreground="{Binding IpBrush}"/>
            </Grid>
        </Border>

        <!-- Live console pane -->
        <Border Grid.Row="3" CornerRadius="14"
                Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Console header: title + clear button -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ConsoleTitle}"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="{Binding ClearBtnLabel}"
                            Command="{Binding ClearConsoleCommand}"
                            MinWidth="80" Height="28" Padding="10,0"
                            FontSize="11" FontWeight="SemiBold"
                            Background="#1E293B" Foreground="#E2E8F0"
                            BorderBrush="#334155" BorderThickness="1"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cbd" CornerRadius="8"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cbd" Property="Background" Value="#334155"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Scrolling line list -->
                <ListBox x:Name="ConsoleList" Grid.Row="1"
                         ItemsSource="{Binding ConsoleLines}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"
                                       FontFamily="Cascadia Mono, Cascadia Code, Consolas"
                                       FontSize="11"
                                       TextWrapping="NoWrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Foreground" Value="#F87171"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                <Setter Property="Foreground" Value="#60A5FA"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="4"
                   Text="{Binding Footer}"
                   FontSize="11"
                   Foreground="{StaticResource BrandTextMuted}"
                   Margin="4,12,0,0"
                   VerticalAlignment="Bottom"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>
