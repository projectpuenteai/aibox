# ============================================================
# AIBox Stack Configuration
# ============================================================
# Copy this file to stack/.env and set the REQUIRED values.
# Optional values show their defaults for reference.
# ============================================================

# ---------- REQUIRED: Security ----------

# 32-byte encryption key, base64-encoded.
# Generate with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Rotating this key invalidates all encrypted documents/chats in storage.
APP_ENCRYPTION_MASTER_KEY=

# Admin account credentials (created on first startup).
# NOTE: ADMIN_DEFAULT_PASSWORD is only applied when the admin user is first
# seeded. To rotate the admin password later, use the admin "reset password"
# endpoint in the portal — changing this env var after seed has no effect.
ADMIN_USERNAME=puenteAdmin
ADMIN_DEFAULT_PASSWORD=

# Session token pepper (any unique random string).
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If unset when APP_ENV!=production, a random pepper is generated per install
# and persisted under <APP_DATA_ROOT>/security/session_pepper.dev (dev only).
SESSION_TOKEN_PEPPER=

# ---------- Optional: Session Cookie / Proxy ----------

# Set APP_ENV=production (default) for strict secret validation.
# Use APP_ENV=dev for local iteration (enables dev fallbacks, logs warnings).
# APP_ENV=production

# Cookie Secure flag. Values: auto (default) | true | false.
# "auto" sets Secure=true when APP_ENV=production and false otherwise.
# If serving the stack on bare HTTP over a LAN, explicitly set this to false,
# otherwise browsers will drop the session cookie and logins will "succeed"
# but immediately appear logged-out.
# SESSION_COOKIE_SECURE=auto

# Cookie SameSite policy. Values: lax (default) | strict | none.
# "strict" breaks any link that opens the portal from an external page.
# "none" REQUIRES Secure=true; do not combine with HTTP deployments.
# SESSION_COOKIE_SAMESITE=lax

# Trust X-Forwarded-For / X-Real-IP when determining client IP.
# KEEP OFF unless the app is behind a proxy you control. When off, the raw
# TCP peer is used so untrusted clients cannot spoof their source IP and
# bypass per-IP login lockouts or signup rate limits.
# TRUST_PROXY_HEADERS=false

# Session lifetime (days).
# SESSION_DAYS=7

# ---------- Optional: Signup Controls ----------

# Allow unauthenticated users to create accounts via /v1/app/auth/signup.
# Set to false to lock account creation to admin-driven flows only.
# ALLOW_PUBLIC_SIGNUP=true

# Max signup attempts per hour from a single source IP. Exceeding returns 429
# and writes a `signup_rate_block` row to the security_events table.
# SIGNUP_MAX_PER_HOUR_PER_IP=5

# ---------- Optional: Login Lockout ----------

# Failures within LOGIN_WINDOW_SECONDS before a lockout kicks in.
# LOGIN_FAIL_LIMIT=5
# LOGIN_WINDOW_SECONDS=900

# ---------- Optional: Llama Runtime ----------

# LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda@sha256:5c9266b4f92f1ab0d26dd0f2ede2e65d3853cad99ff86ba219db8fe6d464b995
# LLAMA_IMAGE_MODE=prebuilt
# LLAMA_MODEL_FILE=qwen2.5-7b-instruct-q4_0-00001-of-00002.gguf
# LLAMA_CTX_SIZE=6144
# LLAMA_N_PREDICT=256
# LLAMA_THREADS=-1
# LLAMA_THREADS_BATCH=-1
# LLAMA_BATCH_SIZE=1024
# LLAMA_UBATCH_SIZE=512
# LLAMA_N_GPU_LAYERS=99
# LLAMA_CONTEXT_SHIFT_KEEP=1000

# ---------- Optional: Data Retention & Cleanup ----------

# How often the background cleanup loop runs (seconds)
# CLEANUP_LOOP_SECONDS=600

# TTL for unbounded database tables (days)
# RATE_EVENTS_RETENTION_DAYS=7
# SECURITY_EVENTS_RETENTION_DAYS=90
# USAGE_EVENTS_RETENTION_DAYS=14
# CLEANUP_EVENTS_RETENTION_DAYS=30
# LOGIN_ATTEMPTS_RETENTION_DAYS=7
# SESSION_RETENTION_DAYS=30

# Hours between SQLite VACUUM runs (reclaims disk from deleted rows)
# VACUUM_INTERVAL_HOURS=24

# ============================================================
# Security Notes (read before deploying)
# ============================================================
# - This app is designed for trusted LAN use. It is NOT hardened for direct
#   public-internet exposure. If you must expose it, put it behind a reverse
#   proxy that terminates TLS and enforces its own auth.
# - Passwords are hashed with Argon2id (argon2-cffi defaults). Document and
#   chat content are encrypted at rest with AES-256-GCM using the master key
#   above.
# - Rotate ADMIN_DEFAULT_PASSWORD in your .env BEFORE first startup. Afterwards
#   changes only take effect via the admin reset endpoint.
# - Security-relevant events (logins, lockouts, admin actions, role changes,
#   signup abuse) are written to the security_events table and retained for
#   SECURITY_EVENTS_RETENTION_DAYS days. Admins can inspect them via the portal.
# ============================================================
