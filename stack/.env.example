# Optional overrides for Docker-native llama runtime.
# Copy this file to stack/.env and edit values as needed.

LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda@sha256:5c9266b4f92f1ab0d26dd0f2ede2e65d3853cad99ff86ba219db8fe6d464b995
LLAMA_IMAGE_MODE=prebuilt
LLAMA_MODEL_FILE=qwen2.5-7b-instruct-q4_0-00001-of-00002.gguf
LLAMA_CTX_SIZE=6144
LLAMA_N_PREDICT=256
LLAMA_THREADS=-1
LLAMA_THREADS_BATCH=-1
LLAMA_BATCH_SIZE=1024
LLAMA_UBATCH_SIZE=512
LLAMA_N_GPU_LAYERS=99
LLAMA_CONTEXT_SHIFT_KEEP=1000

