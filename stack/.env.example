# ============================================================
# AIBox Stack Configuration
# ============================================================
# Copy this file to stack/.env and set the REQUIRED values.
# Optional values show their defaults for reference.
# ============================================================

# ---------- REQUIRED: Security ----------

# 32-byte encryption key, base64-encoded.
# Generate with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
APP_ENCRYPTION_MASTER_KEY=

# Admin account credentials (created on first startup)
ADMIN_USERNAME=puenteAdmin
ADMIN_DEFAULT_PASSWORD=

# Session token pepper (any unique random string)
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(16))"
SESSION_TOKEN_PEPPER=

# ---------- Optional: Llama Runtime ----------

# LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda@sha256:5c9266b4f92f1ab0d26dd0f2ede2e65d3853cad99ff86ba219db8fe6d464b995
# LLAMA_IMAGE_MODE=prebuilt
# LLAMA_MODEL_FILE=qwen2.5-7b-instruct-q4_0-00001-of-00002.gguf
# LLAMA_CTX_SIZE=6144
# LLAMA_N_PREDICT=256
# LLAMA_THREADS=-1
# LLAMA_THREADS_BATCH=-1
# LLAMA_BATCH_SIZE=1024
# LLAMA_UBATCH_SIZE=512
# LLAMA_N_GPU_LAYERS=99
# LLAMA_CONTEXT_SHIFT_KEEP=1000

# ---------- Optional: Data Retention & Cleanup ----------

# How often the background cleanup loop runs (seconds)
# CLEANUP_LOOP_SECONDS=600

# TTL for unbounded database tables (days)
# RATE_EVENTS_RETENTION_DAYS=7
# SECURITY_EVENTS_RETENTION_DAYS=90
# USAGE_EVENTS_RETENTION_DAYS=14
# CLEANUP_EVENTS_RETENTION_DAYS=30
# LOGIN_ATTEMPTS_RETENTION_DAYS=7
# SESSION_RETENTION_DAYS=30

# Hours between SQLite VACUUM runs (reclaims disk from deleted rows)
# VACUUM_INTERVAL_HOURS=24
