:80 {
  log {
    output file /var/log/caddy/access.log {
      roll_size 10mb
      roll_keep 5
      roll_keep_for 168h
    }
    format filter {
      wrap json
      fields {
        request>headers delete
        resp_headers delete
      }
    }
  }

  # ---- Security response headers ----
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    -Server
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
  }

  # ---- Reverse proxy routes ----
  # ai-control can take 30–90s to come up while it loads embedding/rerank
  # models. The proxy passes try_duration so requests queue briefly during
  # warmup instead of hard-erroring; lb_try_interval keeps reconnects cheap.
  handle_path /ai/api/* {
    reverse_proxy ai-control:8081 {
      lb_try_duration 8s
      lb_try_interval 500ms
      fail_duration 5s
      max_fails 3
      transport http {
        dial_timeout 3s
        response_header_timeout 60s
      }
    }
  }

  # Open WebUI is an opt-in debug surface. The chat service only runs when
  # Compose is started with --profile debug-openwebui, and Open WebUI auth is
  # enabled by default.
  handle_path /chat/* {
    reverse_proxy chat:8080
  }

  redir /wiki/en /wiki/en/
  redir /wiki/es /wiki/es/

  handle /wiki/en/* {
    reverse_proxy kiwix-en:8080
  }

  handle /wiki/es/* {
    reverse_proxy kiwix-es:8080
  }

  handle /wiki {
    reverse_proxy ai-control:8081
  }

  handle /wiki/* {
    reverse_proxy ai-control:8081
  }

  @learn_root path /learn /learn/
  redir @learn_root /kolibri/
  # The /learn/* portal shortcut redirects to /kolibri/* — but Kolibri's own
  # Learn plugin exposes API endpoints at /learn/api/* (e.g.
  # /learn/api/learnerclassroom/), which must NOT be redirected. Exclude the
  # API path from the matcher and proxy /learn/api/* straight to Kolibri.
  @learn_sub {
    path_regexp learn_sub ^/learn/(.*)$
    not {
      path /learn/api /learn/api/*
    }
  }
  redir @learn_sub /kolibri/{re.learn_sub.1}

  redir /kolibri /kolibri/

  handle_path /kolibri/* {
    reverse_proxy kolibri:8080 {
      header_down Location ^/(.*)$ /kolibri/$1
    }
  }

  # Backward compatibility: if Kolibri-rooted locale links are hit directly,
  # send users back under the /kolibri prefix.
  @kolibri_locale {
    path_regexp kolibri_locale ^/[a-z]{2}(?:-[A-Za-z0-9]+)?(?:/.*)?$
    not path /ai /ai/* /chat /chat/* /wiki /wiki/* /learn /learn/* /kolibri /kolibri/*
  }
  handle @kolibri_locale {
    redir * /kolibri{uri}
  }

  # Kolibri static/content endpoints may still be rooted at /
  handle /api/* {
    reverse_proxy kolibri:8080
  }
  handle /static/* {
    reverse_proxy kolibri:8080
  }
  handle /content/* {
    reverse_proxy kolibri:8080
  }
  # Kolibri plugins register their own URL roots outside /api/ — the Coach
  # plugin in particular polls /coach/api/notifications/ every ~3s and the
  # whole Coach module wedges into Kolibri's generic error page when that
  # 404s. Other plugins (management, facility, user) can also expose
  # plugin-rooted endpoints. Route them all to Kolibri so the SPA can finish
  # bootstrapping.
  handle /coach/* {
    reverse_proxy kolibri:8080
  }
  handle /facility/api/* {
    reverse_proxy kolibri:8080
  }
  handle /management/api/* {
    reverse_proxy kolibri:8080
  }
  handle /user/api/* {
    reverse_proxy kolibri:8080
  }
  handle /learn/api/* {
    reverse_proxy kolibri:8080
  }

  # ---- Portal homepage fallback ----
  root * /srv/portal

  # ---- Cache-Control for static portal assets ----
  # Layered ADDITIVELY on top of the security `header { … }` block above.
  # Matchers are explicit so individual rules are easy to override later.
  #
  # /assets/*  — fingerprinted/long-lived vendor JS, logos, fonts → 24h immutable
  # *.js / *.css under per-app dirs (ai/, wiki-app/, learn-app/, docs/) → 1h
  # *.html (index.html, connect.html, ai/index.html, …)             → no-cache
  #   so deploys are picked up immediately on next visit.
  @portal_assets path /assets/*
  header @portal_assets Cache-Control "public, max-age=86400, immutable"

  @portal_js_css path *.js *.css
  header @portal_js_css Cache-Control "public, max-age=3600"

  # Match every HTML entry point: literal *.html (e.g. /connect.html), the
  # root /, and the per-app directory roots (/ai/, /docs/, /wiki-app/,
  # /learn-app/) — Caddy resolves those to the directory's index.html via
  # file_server, but the path matcher itself doesn't end in .html, so it
  # would otherwise be missed and get the default (cacheable) response. A
  # stale ai/index.html in the browser is the difference between RAG
  # appearing broken and working, so this matcher must stay broad.
  @portal_html path *.html / /ai/ /docs/ /wiki-app/ /learn-app/ /tutorials/
  header @portal_html Cache-Control "no-cache, no-store, must-revalidate"

  # Dynamic compression for responses that don't have a precompressed sibling
  # on disk (most of the portal — MathJax, markdown-it, ai/index.html, etc.).
  # Layered with `precompressed` below: Caddy serves a pre-built .zst/.gz/.br
  # if one exists, otherwise falls back to on-the-fly zstd/gzip. Proxied
  # responses from ai-control, Kolibri, Kiwix, etc. also get compressed.
  encode zstd gzip

  file_server {
    precompressed zstd gzip br
  }
}
