# Canonical pinned image digests for AIBox.
# - Scripts (preflight, up_stack) read defaults from this file.
# - docker-compose.yaml has its own inline default in ${LLAMA_IMAGE:-...} that
#   should be kept in sync with this file (compose does not read .env.defaults).
# - User-overrides go in stack/.env, which takes precedence.

LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda@sha256:5c9266b4f92f1ab0d26dd0f2ede2e65d3853cad99ff86ba219db8fe6d464b995
VOLUME_PROBE_IMAGE=caddy:2@sha256:ec18ee54aab3315c22e25f3b2babda73ff8007d39b13b3bd1bfffa2f0444c7d9
